# ========================================
# UmbrellaZG 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改
# ========================================

# ===== 应用配置 =====
SPRING_PROFILES_ACTIVE=dev

# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=umbrellazg
DB_USERNAME=app_user
DB_PASSWORD=your_secure_password_here

# 数据库连接池配置
DB_MAX_POOL_SIZE=15
DB_MIN_IDLE=5
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=20000
DB_MAX_LIFETIME=1800000
DB_LEAK_DETECTION_THRESHOLD=5000

# ===== Redis 配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DATABASE=0
REDIS_TIMEOUT=2000

# Redis 连接池配置
REDIS_MAX_ACTIVE=8
REDIS_MAX_IDLE=5
REDIS_MIN_IDLE=1
REDIS_MAX_WAIT=2000
REDIS_SHUTDOWN_TIMEOUT=100

# ===== JWT 安全配置 =====
# 生产环境必须使用强密钥！
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ===== 业务配置 =====
GUEST_EXPIRATION_MS=21600000
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=50MB
FILE_STORAGE_PATH=./uploads
MAX_ATTACHMENT_COUNT=5

# ===== JPA/Hibernate 配置 =====
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=true
HIBERNATE_BATCH_SIZE=20

# ===== 日志配置 =====
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=DEBUG
LOG_LEVEL_SQL=WARN
LOG_LEVEL_SQL_PARAMS=WARN
LOG_FILE_NAME=logs/umbrellazg.log
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_MAX_HISTORY=30

# ===== 缓存配置 =====
CACHE_TTL=300000

# ===== 监控配置 =====
HEALTH_SHOW_DETAILS=when-authorized

# ===== 跨域配置 =====
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# ===== 性能优化配置 =====
ASYNC_CORE_SIZE=5
ASYNC_MAX_SIZE=10
ASYNC_QUEUE_CAPACITY=25

# ===== 开发环境配置 =====
DEVTOOLS_ENABLED=false
LIVERELOAD_ENABLED=false
